# VibeSafely environment variables. Copy to .env.local and fill in.
# .env.local is gitignored; never commit real secrets.

# --- App ---
# Public base URL, used for metadata + Stripe/OAuth redirect URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (Project Settings -> API) ---
# The project URL and the anon (publishable) key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# The service-role key bypasses Row Level Security. SERVER ONLY — never prefix with
# NEXT_PUBLIC and never import into a client component.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (Developers -> API keys / Webhooks / Products) ---
STRIPE_SECRET_KEY=
# Signing secret for the /api/stripe/webhook endpoint (from `stripe listen` locally,
# or the webhook endpoint's signing secret in the dashboard).
STRIPE_WEBHOOK_SECRET=
# Price IDs. One-time price that grants 15 full-scan credits (£9); recurring £19/mo.
STRIPE_PRICE_CREDITS_9=
STRIPE_PRICE_SUB_19=

# --- Dev only ---
# Lets the scanner hit localhost / private targets (e.g. the vuln-demo). Never set in prod.
VIBESAFELY_ALLOW_LOCAL=1
